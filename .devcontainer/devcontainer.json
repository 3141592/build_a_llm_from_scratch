{
  "name": "build_a_llm_from_scratch",
  "image": "dl-base:latest",
  "workspaceFolder": "/workspaces/build_a_llm_from_scratch",
  "runArgs": [
    "--gpus=all"
  ],
  "mounts": [
    "source=/home/roy/src/ai_shared_utilities,target=/workspaces/ai_shared_utilities,type=bind",
    "source=/home/roy/src/data,target=/workspaces/data,type=bind"
  ],
  "postCreateCommand": "pip install -e /workspaces/ai_shared_utilities",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
